<Page x:Class="Unbreakfocuspc.Views.HomePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#000000">

    <Grid Padding="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <RowDefinition Height="Auto"/> <RowDefinition Height="*"/>    </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,30">
            <TextBlock Text="{x:Bind User.Name}" FontSize="32" FontWeight="Bold" Foreground="White"/>
            
            <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,5,0,0">
                <TextBlock Text="MISSION:" FontSize="14" Foreground="#888888" FontWeight="Bold" VerticalAlignment="Center"/>
                <Border Background="#00FFCC" CornerRadius="4" Padding="8,4">
                    <TextBlock Text="{x:Bind User.TargetGoal}" FontSize="12" Foreground="Black" FontWeight="Bold"/>
                </Border>
                <TextBlock Text="{x:Bind DaysLeftString}" FontSize="14" Foreground="#FF3333" FontWeight="Bold" VerticalAlignment="Center" Margin="10,0,0,0"/>
            </StackPanel>
        </StackPanel>

        <Grid Grid.Row="1" ColumnSpacing="20" RowSpacing="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Grid.Column="0" Background="#1A1A1A" CornerRadius="12" Padding="20" BorderBrush="#33FFFFFF" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="CURRENT RANK" FontSize="12" Foreground="#888888" FontWeight="Bold"/>
                    <TextBlock Text="{x:Bind CurrentLevelString}" FontSize="40" Foreground="#FBBF24" FontWeight="Bold" Margin="0,5,0,0"/>
                </StackPanel>
            </Border>

            <Border Grid.Row="0" Grid.Column="1" Background="#1A1A1A" CornerRadius="12" Padding="20" BorderBrush="#33FFFFFF" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="LIFETIME XP" FontSize="12" Foreground="#888888" FontWeight="Bold"/>
                    <TextBlock Text="{x:Bind LifetimeXPString}" FontSize="40" Foreground="#38BDF8" FontWeight="Bold" Margin="0,5,0,0"/>
                </StackPanel>
            </Border>

            <Border Grid.Row="0" Grid.Column="2" Background="#1A1A1A" CornerRadius="12" Padding="20" BorderBrush="#33FFFFFF" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="WALLET XP" FontSize="12" Foreground="#888888" FontWeight="Bold"/>
                    <TextBlock Text="{x:Bind LifetimeXPString}" FontSize="40" Foreground="#34D399" FontWeight="Bold" Margin="0,5,0,0"/>
                </StackPanel>
            </Border>

            <Border Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Background="#1A1A1A" CornerRadius="12" Padding="20" BorderBrush="#33FFFFFF" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="LIFETIME FOCUS ARCHIVE" FontSize="12" Foreground="#888888" FontWeight="Bold"/>
                    <TextBlock Text="{x:Bind TotalTimeString}" FontSize="40" Foreground="White" FontWeight="Bold" Margin="0,5,0,0"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Page>