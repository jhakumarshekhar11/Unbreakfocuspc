<Window x:Class="UnbreakfocusPC.BlockerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="FOCUS BREACHED" Background="#EF4444" 
        WindowStyle="None" WindowState="Maximized" Topmost="True" ShowInTaskbar="False">
    <Grid>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock Text="FOCUS BREACHED" FontSize="90" FontWeight="Black" Foreground="White" HorizontalAlignment="Center"/>
            <TextBlock Text="CLOSE THE DISTRACTION IMMEDIATELY" FontSize="32" Foreground="White" HorizontalAlignment="Center" Margin="0,20,0,0"/>
            <TextBlock x:Name="TxtPenalty" Text="STRICT MODE: DO NOT ATTEMPT TO OVERRIDE" FontSize="18" Foreground="#7F1D1D" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,40,0,0"/>
            
            <Button x:Name="BtnOverride" Content="OVERRIDE &amp; ACCEPT PENALTY (-150 XP)" 
                    Click="Override_Click" Background="Transparent" Foreground="#EF4444" 
                    BorderBrush="#EF4444" BorderThickness="2" Padding="20,10" 
                    Margin="0,40,0,0" FontWeight="Bold" Visibility="Collapsed"/>
        </StackPanel>
    </Grid>
</Window>