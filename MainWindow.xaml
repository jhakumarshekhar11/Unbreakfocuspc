<Window x:Class="UnbreakfocusPC.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Unbreakfocus PC" Height="700" Width="1000" Background="#0A0A0A" 
        WindowStyle="None" AllowsTransparency="True"
        Icon="Assets/logo.ico">
    <Grid>
        <Border Background="#0A0A0A" Opacity="0.9" CornerRadius="15"/>
        
        <Grid x:Name="MainContainer">
            <StackPanel Width="80" HorizontalAlignment="Left" Background="#111111">
                <Button Content="Hub" Click="Nav_Hub" Margin="5,50,5,10" Background="Transparent" Foreground="#38BDF8" BorderBrush="Transparent"/>
                <Button Content="Focus" Click="Nav_Focus" Margin="5,10" Background="Transparent" Foreground="#34D399" BorderBrush="Transparent"/>
                <Button Content="Store" Click="Nav_Store" Margin="5,10" Background="Transparent" Foreground="#FBBF24" BorderBrush="Transparent"/>
            </StackPanel>

            <Grid Margin="80,0,0,0">
                <StackPanel x:Name="HubView" Visibility="Visible" Margin="40">
                    <Image Source="pack://application:,,,/Assets/logo.png" Height="48" HorizontalAlignment="Left" Margin="0,0,0,15" RenderOptions.BitmapScalingMode="HighQuality"/>
                    <TextBlock x:Name="TxtUser" FontSize="32" FontWeight="Bold" Foreground="#38BDF8"/>
                    <TextBlock x:Name="TxtRank" FontSize="18" Margin="0,5"/>
                    <ProgressBar x:Name="XPBar" Height="10" Background="#222" Foreground="#34D399" Margin="0,20"/>
                    <TextBlock x:Name="TxtStreak" FontSize="14" Foreground="#FBBF24"/>
                </StackPanel>

                <StackPanel x:Name="FocusView" Visibility="Collapsed" Margin="40">
                    <TextBlock Text="SUBJECTS" FontSize="24" Margin="0,0,0,20"/>
                    <ItemsControl x:Name="SubjectList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#1A1A1A" Margin="0,5" Padding="15" CornerRadius="8">
                                    <DockPanel>
                                        <TextBlock Text="{Binding Name}" VerticalAlignment="Center" FontSize="18"/>
                                        <Button Content="START SHIELD" Click="StartFocus_Click" Tag="{Binding}" HorizontalAlignment="Right" Background="#38BDF8" Foreground="Black" Padding="10,5"/>
                                    </DockPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <Grid x:Name="StoreView" Visibility="Collapsed" Margin="40">
                    <StackPanel>
                        <TextBlock Text="MARKET" FontSize="24"/>
                        <Border Background="#1A1A1A" Padding="20" Margin="0,20" CornerRadius="10">
                            <DockPanel>
                                <TextBlock Text="Streak Freeze" FontSize="18" VerticalAlignment="Center"/>
                                <Button Content="1500 XP" Click="BuyFreeze_Click" HorizontalAlignment="Right" Background="#FBBF24" Foreground="Black" Padding="15,5"/>
                            </DockPanel>
                        </Border>
                    </StackPanel>
                </Grid>

                <Grid x:Name="EngineView" Visibility="Collapsed" Background="#0A0A0A">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock x:Name="TxtTimer" Text="25:00" FontSize="120" HorizontalAlignment="Center" Foreground="#34D399"/>
                        <TextBlock x:Name="TxtFocusStatus" Text="FLOW STATE ACTIVE" HorizontalAlignment="Center" Foreground="#38BDF8"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Grid>

        <Grid x:Name="BlockerOverlay" Visibility="Collapsed" Background="#EF4444">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="FOCUS BREACHED" FontSize="72" FontWeight="Black" Foreground="White"/>
                <TextBlock Text="RETURN TO WORK IMMEDIATELY" FontSize="24" HorizontalAlignment="Center"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>