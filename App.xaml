<Application x:Class="UnbreakfocusPC.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ui:ThemesDictionary Theme="Dark" />
                <ui:ControlsDictionary />
            </ResourceDictionary.MergedDictionaries>

            <SolidColorBrush x:Key="OLEDBlack" Color="#0A0A0A"/>
            <SolidColorBrush x:Key="SkyBlue" Color="#38BDF8"/>
            <SolidColorBrush x:Key="Emerald" Color="#34D399"/>
            <SolidColorBrush x:Key="AlertRed" Color="#EF4444"/>
            <SolidColorBrush x:Key="AmberXP" Color="#FBBF24"/>

            <Style x:Key="PlaceholderTextBox" TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                <Style.Resources>
                    <VisualBrush x:Key="HelpBrush" TileMode="None" Stretch="None" AlignmentX="Left">
                        <VisualBrush.Visual>
                            <TextBlock ItemName="HelpText" Text="{Binding Path=Tag, RelativeSource={RelativeSource TemplatedParent}}" Foreground="Gray" Margin="5,0,0,0"/>
                        </VisualBrush.Visual>
                    </VisualBrush>
                </Style.Resources>
                <Style.Triggers>
                    <Trigger Property="Text" Value="{x:Null}">
                        <Setter Property="Background" Value="{StaticResource HelpBrush}"/>
                    </Trigger>
                    <Trigger Property="Text" Value="">
                        <Setter Property="Background" Value="{StaticResource HelpBrush}"/>
                    </Trigger>
                </Style.Triggers>
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>