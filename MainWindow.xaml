<Window
    x:Class="Unbreakfocuspc.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Unbreakfocuspc"
    Title="Unbreakfocus">

    <Window.SystemBackdrop>
        <MicaBackdrop Kind="Base" />
    </Window.SystemBackdrop>

    <Grid RequestedTheme="Dark" Background="#E60A0A0A">
        <Grid.Resources>
            <Storyboard x:Name="FadeInOverlay">
                <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0.0" To="1.0" Duration="0:0:0.2"/>
            </Storyboard>
        </Grid.Resources>

        <NavigationView x:Name="MainNav" SelectionChanged="MainNav_SelectionChanged" IsSettingsVisible="True" IsBackButtonVisible="Collapsed">
            
            <NavigationView.PaneHeader>
                <Grid Padding="12,10,12,10">
                    <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Left">
                        <Image Source="Assets/logo.png" Width="28" Height="28" Stretch="Uniform"/>
                        <TextBlock Text="UNBREAKFOCUS" VerticalAlignment="Center" FontWeight="Black" FontSize="14" CharacterSpacing="200" Foreground="#38BDF8"/>
                    </StackPanel>
                    <Button x:Name="FullScreenBtn" Click="FullScreen_Click" Background="Transparent" BorderThickness="0" HorizontalAlignment="Right">
                        <SymbolIcon Symbol="FullScreen" Foreground="White"/>
                    </Button>
                </Grid>
            </NavigationView.PaneHeader>

            <NavigationView.MenuItems>
                <NavigationViewItem Tag="Hub" Content="Hub">
                    <NavigationViewItem.Icon><SymbolIcon Symbol="Home"/></NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Tag="Focus" Content="Focus Engine">
                    <NavigationViewItem.Icon><SymbolIcon Symbol="Clock"/></NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>

            <Grid Padding="20">
                
                <ScrollViewer x:Name="HubView" Visibility="Visible">
                    <StackPanel Spacing="20" MaxWidth="800" HorizontalAlignment="Left">
                        <Grid>
                            <TextBlock Text="MISSION LOGBOOK" FontSize="24" FontWeight="Bold" Foreground="#38BDF8"/>
                            <TextBlock x:Name="TargetCountdownTxt" FontSize="16" FontWeight="Black" Foreground="White" HorizontalAlignment="Right" VerticalAlignment="Bottom"/>
                        </Grid>
                        
                        <Border Background="#262626" CornerRadius="12" Padding="20">
                            <StackPanel>
                                <TextBlock x:Name="UserNameTxt" FontSize="18" FontWeight="Bold"/>
                                <TextBlock x:Name="XpTxt" Foreground="#FBBF24" FontWeight="Bold" Margin="0,5,0,0"/>
                                <ProgressBar x:Name="LevelProgress" Height="8" Margin="0,10,0,0" Foreground="#38BDF8"/>
                            </StackPanel>
                        </Border>
                        
                        <Grid ColumnDefinitions="*,*">
                            <Button Grid.Column="0" Click="ShowStreakAnalytics_Click" Background="#161616" CornerRadius="12" Padding="20" Margin="0,0,10,0" BorderBrush="#FB923C" BorderThickness="1" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left">
                                <StackPanel>
                                    <TextBlock Text="STREAK" Foreground="#FB923C" FontSize="12"/>
                                    <TextBlock x:Name="StreakTxt" FontSize="28" FontWeight="Bold" Foreground="White"/>
                                </StackPanel>
                            </Button>
                            <Button Grid.Column="1" Click="ShowStreakAnalytics_Click" Background="#161616" CornerRadius="12" Padding="20" Margin="10,0,0,0" BorderBrush="#34D399" BorderThickness="1" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left">
                                <StackPanel>
                                    <TextBlock Text="TODAY'S FOCUS" Foreground="#34D399" FontSize="12"/>
                                    <TextBlock x:Name="TodayFocusTxt" FontSize="28" FontWeight="Bold" Foreground="White"/>
                                </StackPanel>
                            </Button>
                        </Grid>

                        <TextBlock Text="THIS MONTH'S HISTORY" FontSize="14" FontWeight="Bold" Foreground="Gray" Margin="0,10,0,0"/>
                        <Border Background="#161616" CornerRadius="12" Padding="15" BorderBrush="#262626" BorderThickness="1">
                            <ItemsControl x:Name="CalendarGrid">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <VariableSizedWrapGrid Orientation="Horizontal" MaximumRowsOrColumns="7"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="local:CalendarDay">
                                        <Border Width="40" Height="40" Margin="5" CornerRadius="8" Background="{x:Bind HexColor}" BorderBrush="White" BorderThickness="{x:Bind BorderSize}">
                                            <TextBlock Text="{x:Bind Day}" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White" FontWeight="Bold"/>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <Grid x:Name="FocusView" Visibility="Collapsed">
                    
                    <StackPanel x:Name="SubjectDashboard" Visibility="Visible" Spacing="20" MaxWidth="800" HorizontalAlignment="Left">
                        <Grid>
                            <TextBlock Text="SUBJECTS" FontSize="24" FontWeight="Bold" Foreground="#38BDF8"/>
                            <Button Content="+ NEW SUBJECT" Background="#38BDF8" Foreground="Black" FontWeight="Bold" HorizontalAlignment="Right" Click="OpenSubjectEditor_Click"/>
                        </Grid>

                        <ListView x:Name="SubjectsList" SelectionMode="None" CanReorderItems="True" AllowDrop="True">
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="local:Subject">
                                    <Border Background="#161616" CornerRadius="12" Padding="15" Margin="0,0,0,10" BorderBrush="#262626" BorderThickness="1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="{x:Bind Name}" FontWeight="Bold" Foreground="White" FontSize="16"/>
                                                
                                                <TextBlock Foreground="Gray" FontSize="12" Margin="0,4,0,0">
                                                    <Run Text="{x:Bind GoalMins}"/>
                                                    <Run Text=" MINS GOAL"/>
                                                </TextBlock>
                                            </StackPanel>
                                            
                                            <Button Grid.Column="1" Margin="0,0,10,0" Background="Transparent" BorderThickness="0" Click="EditSubject_Click" Tag="{x:Bind Id}">
                                                <SymbolIcon Symbol="Edit" Foreground="Gray"/>
                                            </Button>
                                            
                                            <Button Grid.Column="2" Background="#38BDF8" Foreground="Black" CornerRadius="20" Width="40" Height="40" Click="LaunchEngine_Click" Tag="{x:Bind Id}">
                                                <SymbolIcon Symbol="Play"/>
                                            </Button>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>

                    <StackPanel x:Name="ActiveEngineView" Visibility="Collapsed" Spacing="20" VerticalAlignment="Center">
                        <TextBlock x:Name="EngineSubjectTxt" FontSize="18" FontWeight="Bold" Foreground="#34D399" HorizontalAlignment="Center" CharacterSpacing="200"/>
                        <TextBlock x:Name="TimerDisplay" FontSize="100" FontWeight="Bold" FontFamily="Consolas" HorizontalAlignment="Center" Margin="0,20,0,0"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="20" Margin="0,40,0,0">
                            <Button Content="PAUSE / RESUME" Background="#38BDF8" Foreground="Black" FontWeight="Bold" Width="150" Height="50" Click="StartTimer_Click"/>
                            <Button Content="ABORT" Background="#EF4444" Foreground="White" FontWeight="Bold" Width="150" Height="50" Click="AbortTimer_Click"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>

                <StackPanel x:Name="SettingsView" Visibility="Collapsed" Spacing="20" MaxWidth="600" HorizontalAlignment="Left">
                    <TextBlock Text="SYSTEM PREFERENCES" FontSize="24" FontWeight="Bold" Foreground="#38BDF8"/>
                    <Border Background="#161616" CornerRadius="12" Padding="20" BorderBrush="#262626" BorderThickness="1">
                        <StackPanel Spacing="15">
                            <StackPanel>
                                <ToggleSwitch x:Name="StrictModeToggle" Header="Strict Mode" Toggled="StrictMode_Toggled" />
                                <TextBlock Text="Lock focus engine until midnight. Severe XP penalties for aborting." FontSize="12" Foreground="Gray" Margin="0,-5,0,0"/>
                            </StackPanel>
                            <Button Content="VIEW CONSTRUCTORS (CREDITS)" Click="ShowCredits_Click" Background="#262626" Foreground="White" HorizontalAlignment="Stretch"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
                
                <Grid x:Name="SubjectEditorOverlay" Visibility="Collapsed" Canvas.ZIndex="40" Background="#CC0A0A0A" Margin="-20">
                    <Border Background="#161616" CornerRadius="16" Padding="30" Width="400" VerticalAlignment="Center" HorizontalAlignment="Center" BorderBrush="#262626" BorderThickness="1">
                        <StackPanel Spacing="20">
                            <TextBlock x:Name="SubjectEditorTitle" Text="NEW SUBJECT" FontSize="20" FontWeight="Black" Foreground="White"/>
                            <TextBox x:Name="SubjectNameEntry" Header="Subject Name" PlaceholderText="e.g. Mathematics"/>
                            <TextBox x:Name="SubjectGoalEntry" Header="Daily Goal (Minutes)" PlaceholderText="60"/>
                            <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right" Margin="0,20,0,0">
                                <Button Content="CANCEL" Background="Transparent" Foreground="Gray" Click="CloseSubjectEditor_Click"/>
                                <Button Content="SAVE SUBJECT" Background="#38BDF8" Foreground="Black" FontWeight="Bold" Click="SaveSubject_Click"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>

                <Grid x:Name="AnalyticsOverlay" Visibility="Collapsed" Canvas.ZIndex="45" Background="#CC0A0A0A" Margin="-20">
                    <Border Background="#161616" CornerRadius="16" Padding="30" Width="400" VerticalAlignment="Center" HorizontalAlignment="Center" BorderBrush="#FB923C" BorderThickness="1">
                        <StackPanel Spacing="20" HorizontalAlignment="Center">
                            <SymbolIcon Symbol="Target" Foreground="#FB923C"/>
                            <TextBlock Text="PERFORMANCE METRICS" FontSize="20" FontWeight="Black" Foreground="White" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="AnalyticsDetailsTxt" Foreground="WhiteSmoke" TextWrapping="WrapWholeWords" TextAlignment="Center" LineHeight="24"/>
                            <Button Content="CLOSE" Background="#38BDF8" Foreground="Black" FontWeight="Bold" HorizontalAlignment="Stretch" Margin="0,20,0,0" Click="CloseAnalytics_Click"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <Grid x:Name="OnboardingOverlay" Visibility="Collapsed" Canvas.ZIndex="50" Background="#E60A0A0A" Margin="-20">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="20" Width="400">
                        <Image Source="Assets/logo.png" Width="80" Height="80"/>
                        <TextBlock Text="ESTABLISH IDENTITY" FontSize="28" FontWeight="Black" HorizontalAlignment="Center" Foreground="White"/>
                        <TextBox x:Name="NewUserNameEntry" Header="Codename / Name" PlaceholderText="Enter your name..." Foreground="White"/>
                        <ComboBox x:Name="TargetPicker" Header="Mission Target" HorizontalAlignment="Stretch" SelectedIndex="0">
                            <ComboBoxItem Content="Class 10th ICSE"/>
                            <ComboBoxItem Content="Class 12th CBSE"/>
                            <ComboBoxItem Content="JEE / NEET"/>
                            <ComboBoxItem Content="Custom"/>
                        </ComboBox>
                        <DatePicker x:Name="TargetDateEntry" Header="Target Date"/>
                        <Button Content="INITIALIZE SHIELD" HorizontalAlignment="Stretch" Height="50" Margin="0,20,0,0" Background="#38BDF8" Foreground="Black" FontWeight="Bold" Click="InitializeProfile_Click"/>
                    </StackPanel>
                </Grid>

                <Grid x:Name="OverlayBlocker" Visibility="Collapsed" Canvas.ZIndex="100" Background="#E6000000" Margin="-20">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="20">
                        <TextBlock Text="FOCUS BREACHED" Foreground="#EF4444" FontSize="48" FontWeight="Bold" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="DistractedAppTxt" Foreground="White" FontSize="20" HorizontalAlignment="Center"/>
                        <Button Content="RETURN TO FOCUS" Background="#EF4444" Foreground="White" HorizontalAlignment="Center" Margin="0,30,0,0" Click="DismissBlocker_Click"/>
                    </StackPanel>
                </Grid>

            </Grid>
        </NavigationView>
    </Grid>
</Window>