<Page x:Class="Unbreakfocuspc.Views.ShellPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#000000">

    <Page.Resources>
        <Thickness x:Key="NavigationViewContentGridBorderThickness">0</Thickness>
        <SolidColorBrush x:Key="NavigationViewContentBackground" Color="#000000"/>
        <SolidColorBrush x:Key="NavigationViewExpandedPaneBackground" Color="#000000"/>
    </Page.Resources>

    <NavigationView x:Name="Sidebar" 
                    PaneDisplayMode="Left" 
                    IsSettingsVisible="False"
                    ItemInvoked="Sidebar_ItemInvoked"
                    Background="#000000">
        
        <NavigationView.PaneHeader>
            <StackPanel Orientation="Horizontal" Padding="16,12,0,12" Spacing="12">
                <Image Source="ms-appx:///Assets/logo44.png" Width="24" Height="24"/>
                <TextBlock Text="UNBREAKFOCUS" 
                           FontSize="14" 
                           FontWeight="Bold" 
                           VerticalAlignment="Center" 
                           Foreground="#00FFCC"
                           CharacterSpacing="100"/>
            </StackPanel>
        </NavigationView.PaneHeader>

        <NavigationView.MenuItems>
            <NavigationViewItem Tag="Home" Content="Home" Icon="Home" />
            <NavigationViewItem Tag="Focus" Content="Focus" Icon="Clock" />
        </NavigationView.MenuItems>

        <NavigationView.FooterMenuItems>
            <NavigationViewItem Tag="Settings" Content="Settings" Icon="Setting" />
        </NavigationView.FooterMenuItems>

        <Frame x:Name="ContentFrame" Padding="20" />
        
    </NavigationView>
</Page>