<ui:FluentWindow x:Class="UnbreakfocusPC.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Unbreakfocus PC" Height="750" Width="1100" MinWidth="800" MinHeight="600"
        WindowBackdropType="Mica" Background="Transparent" ExtendsContentIntoTitleBar="True" Icon="Assets/logo.ico">
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Unbreakfocus PC" Icon="pack://application:,,,/Assets/logo.png" Margin="0,0,0,10"/>

        <Grid x:Name="PinLockOverlay" Visibility="Collapsed" Background="#0A0A0A" Panel.ZIndex="999" Grid.RowSpan="2">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="300">
                <ui:SymbolIcon Symbol="LockShield24" FontSize="64" Foreground="#EF4444" HorizontalAlignment="Center" Margin="0,0,0,20"/>
                <TextBlock Text="SYSTEM LOCKED" FontSize="24" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,20"/>
                <PasswordBox x:Name="TxtUnlockPin" MaxLength="4" Background="#222" Foreground="White" HorizontalContentAlignment="Center" FontSize="24" Margin="0,0,0,10"/>
                <Button Content="AUTHORIZE ACCESS" Click="UnlockApp_Click" Background="#EF4444" Foreground="White" Width="200" HorizontalAlignment="Center" Padding="10"/>
                <TextBlock x:Name="TxtLockError" Foreground="#EF4444" HorizontalAlignment="Center" Margin="0,10,0,0" Visibility="Collapsed"/>
            </StackPanel>
        </Grid>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <Grid x:Name="MainContainer">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Background="#80000000">
                    <ui:Button Click="Nav_Hub" Margin="5,20,5,10" Appearance="Transparent" Width="70" Height="60">
                        <StackPanel>
                            <ui:SymbolIcon Symbol="Home24" Foreground="#38BDF8" FontSize="24" HorizontalAlignment="Center"/>
                            <TextBlock Text="Hub" Foreground="#38BDF8" FontSize="10" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </ui:Button>
                    <ui:Button Click="Nav_Focus" Margin="5,10" Appearance="Transparent" Width="70" Height="60">
                        <StackPanel>
                            <ui:SymbolIcon Symbol="Target24" Foreground="#34D399" FontSize="24" HorizontalAlignment="Center"/>
                            <TextBlock Text="Focus" Foreground="#34D399" FontSize="10" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </ui:Button>
                    <ui:Button Click="Nav_Store" Margin="5,10" Appearance="Transparent" Width="70" Height="60">
                        <StackPanel>
                            <ui:SymbolIcon Symbol="Cart24" Foreground="#FBBF24" FontSize="24" HorizontalAlignment="Center"/>
                            <TextBlock Text="Store" Foreground="#FBBF24" FontSize="10" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </ui:Button>
                    <ui:Button Click="Nav_Settings" Margin="5,10" Appearance="Transparent" Width="70" Height="60">
                        <StackPanel>
                            <ui:SymbolIcon Symbol="Settings24" Foreground="Gray" FontSize="24" HorizontalAlignment="Center"/>
                            <TextBlock Text="Config" Foreground="Gray" FontSize="10" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </ui:Button>
                </StackPanel>

                <Grid Grid.Column="1">
                    
                    <StackPanel x:Name="HubView" Visibility="Visible" Margin="40">
                        <TextBlock x:Name="TxtUser" FontSize="32" FontWeight="Bold" Foreground="#38BDF8"/>
                        <TextBlock x:Name="TxtRank" FontSize="18" Margin="0,5"/>
                        <ProgressBar x:Name="XPBar" Height="10" Background="#222" Foreground="#34D399" Margin="0,20"/>
                        <TextBlock x:Name="TxtStreak" FontSize="14" Foreground="#FBBF24" Margin="0,0,0,30"/>
                        
                        <TextBlock Text="30-DAY MISSION LOG" FontSize="16" Foreground="White" Margin="0,0,0,10"/>
                        <UniformGrid x:Name="HeatmapGrid" Columns="10" Rows="3" HorizontalAlignment="Left" VerticalAlignment="Top"/>
                    </StackPanel>

                    <Grid x:Name="FocusView" Visibility="Collapsed" Margin="40">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        
                        <TextBlock Grid.Row="0" Text="SUBJECTS" FontSize="24" Margin="0,0,0,20"/>
                        
                        <ScrollViewer Grid.Row="1">
                            <ItemsControl x:Name="SubjectList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#801A1A1A" Margin="0,5,10,5" Padding="15" CornerRadius="8">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Name}" FontSize="18" FontWeight="SemiBold"/>
                                                    <TextBlock Text="{Binding GoalMins, StringFormat='{}Goal: {0} mins'}" FontSize="12" Foreground="#888"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                    <ui:Button Icon="{ui:SymbolIcon Symbol=Delete24}" Click="DeleteSub_Click" Tag="{Binding}" Appearance="Danger" Margin="0,0,15,0"/>
                                                    <Button Content="START SHIELD" Click="StartFocus_Click" Tag="{Binding}" Background="#38BDF8" Foreground="Black" Padding="15,5" FontWeight="Bold"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>

                        <Border Grid.Row="2" Background="#80111111" Padding="15" CornerRadius="8" Margin="0,20,10,0">
                            <DockPanel>
                                <TextBlock Text="NEW:" VerticalAlignment="Center" Margin="0,0,10,0" Foreground="#34D399"/>
                                <TextBox x:Name="TxtSubName" Width="200" Text="Subject Name" GotFocus="ClearPlaceholder" Margin="0,0,10,0"/>
                                <TextBox x:Name="TxtSubMins" Width="80" Text="Mins" GotFocus="ClearPlaceholder" Margin="0,0,10,0"/>
                                <Button Content="ADD" Click="AddSub_Click" Background="#34D399" Foreground="Black" HorizontalAlignment="Right"/>
                            </DockPanel>
                        </Border>
                    </Grid>

                    <Grid x:Name="StoreView" Visibility="Collapsed" Margin="40">
                        <StackPanel>
                            <TextBlock Text="MARKET" FontSize="24"/>
                            <Border Background="#801A1A1A" Padding="20" Margin="0,20" CornerRadius="10">
                                <DockPanel>
                                    <TextBlock Text="Streak Freeze" FontSize="18" VerticalAlignment="Center"/>
                                    <Button Content="1500 XP" Click="BuyFreeze_Click" HorizontalAlignment="Right" Background="#FBBF24" Foreground="Black" Padding="15,5"/>
                                </DockPanel>
                            </Border>
                        </StackPanel>
                    </Grid>

                    <StackPanel x:Name="SettingsView" Visibility="Collapsed" Margin="40">
                        <TextBlock Text="SYSTEM CONFIGURATION" FontSize="24" Margin="0,0,0,20"/>
                        
                        <Border Background="#801A1A1A" Padding="20" CornerRadius="10">
                            <StackPanel>
                                <TextBlock Text="Operator Name:" Foreground="#888" Margin="0,0,0,5"/>
                                <TextBox x:Name="TxtEditName" Background="#222" Foreground="White" Margin="0,0,0,15"/>
                                
                                <TextBlock Text="Update Security PIN (4 Digits):" Foreground="#888" Margin="0,0,0,5"/>
                                <PasswordBox x:Name="TxtEditPin" Background="#222" Foreground="White" MaxLength="4" Margin="0,0,0,20"/>
                                
                                <CheckBox x:Name="ChkStartup" Content="Launch on Windows Startup" Foreground="White" Margin="0,0,0,20" Checked="StartupToggle_Changed" Unchecked="StartupToggle_Changed"/>
                                
                                <Button Content="SAVE CONFIGURATION" Click="SaveSettings_Click" Background="#38BDF8" Foreground="Black" Padding="15,5" FontWeight="Bold"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <Grid x:Name="EngineView" Visibility="Collapsed" Background="#0A0A0A" Panel.ZIndex="50">
                        <Grid VerticalAlignment="Center" HorizontalAlignment="Center">
                            <ui:ProgressRing x:Name="TimerRing" Progress="100" Width="400" Height="400" Foreground="#34D399" Background="#222" IsIndeterminate="False"/>
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock x:Name="TxtTimer" Text="25:00" FontSize="80" HorizontalAlignment="Center" Foreground="#34D399" FontWeight="Light"/>
                                <TextBlock Text="SHIELD ACTIVE - NO BREAKS ALLOWED" HorizontalAlignment="Center" Foreground="#38BDF8" Margin="0,10,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Grid>
            </Grid>
        </ScrollViewer>
    </Grid>
</ui:FluentWindow>